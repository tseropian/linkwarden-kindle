{
  "name": "linkwarden-to-kindle",
  "version": "0.1.0",
  "description": "Send LinkWarden saved articles to Kindle via Send-to-Kindle email",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "send": "tsx src/index.ts --mode send",
    "digest": "tsx src/index.ts --mode digest",
    "list": "tsx src/index.ts --mode list"
  },
  "dependencies": {
    "nodemailer": "^8.0.4",
    "epub-gen-memory": "^1.1.2",
    "node-html-parser": "^7.1.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
