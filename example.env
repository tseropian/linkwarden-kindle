# LinkWarden Configuration
LINKWARDEN_URL=http://localhost:3000
LINKWARDEN_ACCESS_TOKEN=your_access_token_here

# Tag to watch for articles to send to Kindle
# Create a tag called "kindle" in LinkWarden and use its ID here
LINKWARDEN_TAG_ID=1

# Tag name to apply after sending (so we don't re-send)
LINKWARDEN_SENT_TAG_NAME=kindle-sent

# Kindle Configuration
KINDLE_EMAIL=your_kindle_name@kindle.com

# SMTP Configuration (for Send-to-Kindle email)
# Gmail example: smtp.gmail.com / 587 (use an App Password)
# Fastmail: smtp.fastmail.com / 465
# Self-hosted: your SMTP server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# The "from" address must be in your Kindle's Approved Personal Document E-mail List
SMTP_FROM=your_email@gmail.com

# Send mode: "individual" sends each article separately, "digest" bundles into one EPUB
SEND_MODE=individual

# For digest mode: how many articles per digest (0 = all available)
DIGEST_MAX_ARTICLES=20
